      "source": [
        "# 01_Time_Converter.py\n",
        "\n",
        "minutes = int(input(\"Enter minutes: \"))\n",
        "\n",
        "hours = minutes // 60\n",
        "remaining_minutes = minutes % 60\n",
        "\n",
        "# Formatting output properly\n",
        "if hours == 1:\n",
        "    print(f\"{hours} hr {remaining_minutes} minutes\")\n",
        "else:\n",
        "    print(f\"{hours} hrs {remaining_minutes} minutes\")"
      ]
    }
  ]
